#!/usr/bin/env bash

RED='\033[1;31m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; CYAN='\033[1;36m'; WHITE='\033[1;37m'; NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}[ERROR] Please run this script as root (using sudo)${NC}\n\n"
  exit 1
fi

USER_HOME=$(eval echo ~$SUDO_USER)
[[ -z "$USER_HOME" || "$USER_HOME" == "/" ]] && USER_HOME=$HOME

PROTECTED_REGEX="(code|vscode|codium|docker|containers|podman|distrobox|toolbox|timeshift|ubuntu|arch|fedora|debian|alpine|gtk|dconf|font|pulse|mime|systemd|user-dirs)"

echo -e "${CYAN}========================================${NC}\n\n"

echo -e "  🚀 Linux Master Cleaner\n\n"

echo -e "${CYAN}========================================${NC}\n\n"

if [ -f /etc/os-release ]; then . /etc/os-release; OS=$ID; OS_LIKE=$ID_LIKE; fi

echo -e "  ${YELLOW}[1/2]${NC} 🔵 ${CYAN}Scanning${NC} 🔴 ${RED}Garbage${NC} & Orphans...\n\n"

TARGETS=("/var/spool/abrt" "/var/crash" "/var/lib/systemd/coredump" "$USER_HOME/.cache/thumbnails")

if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then TARGETS+=("/var/cache/dnf")
elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then TARGETS+=("/var/cache/apt/archives")
elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then TARGETS+=("/var/cache/pacman/pkg"); fi

if [ -d "$USER_HOME/.cache" ]; then
    while IFS= read -r -d '' dir; do TARGETS+=("$dir")
    done < <(find "$USER_HOME/.cache" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null | grep -z -E -v -i "$PROTECTED_REGEX")
fi

for base_dir in "$USER_HOME/.config" "$USER_HOME/.local/share"; do
    if [ -d "$base_dir" ]; then
        for DIR_PATH in "$base_dir"/*; do
            [ ! -d "$DIR_PATH" ] && continue
            DIR_NAME=$(basename "$DIR_PATH" | tr '[:upper:]' '[:lower:]')
            [[ "$DIR_NAME" =~ $PROTECTED_REGEX ]] && continue
            BASE_NAME="${DIR_NAME%-*}"
            if ! command -v "$DIR_NAME" &> /dev/null && ! command -v "$BASE_NAME" &> /dev/null; then
                TARGETS+=("$DIR_PATH")
            fi
        done
    fi
done

VALID_TARGETS=()
for d in "${TARGETS[@]}"; do
    if sudo sh -c "[ -d \"$d\" ]"; then VALID_TARGETS+=("$d"); fi
done
TARGETS=("${VALID_TARGETS[@]}")

while [ ${#TARGETS[@]} -gt 0 ]; do
    echo -e "🔍 Found disposable caches and orphans:\n\n"
    sudo du -shc "${TARGETS[@]}" 2>/dev/null | grep -v "total"
    TOTAL_CACHE=$(sudo du -shc "${TARGETS[@]}" 2>/dev/null | grep "total" | awk '{print $1}')
    
    echo -e "\nTotal Wasted Space: \033[1;31m$TOTAL_CACHE\033[0m\n\n"
    
    echo -e "  1. ✅ 🟢 ${GREEN}Approve${NC} & 🔴 ${RED}Delete${NC} All\n\n"
    
    echo -e "  2. ➕ Add 🟡 ${YELLOW}Exception${NC} (Skip a folder)\n\n"
    
    echo -e "  0. ❌ ⚪ ${WHITE}Skip${NC} Cleanup\n\n"
    
    read -p "👉 Choice (0-2): " choice
    echo -e "\n\n"
    
    if [[ "$choice" == "1" ]]; then
        for t in "${TARGETS[@]}"; do sudo rm -rf "$t" 2>/dev/null; done
        echo -e "  ✅ [OK] 🔴 ${RED}Garbage${NC} cleared.\n\n"; break
    elif [[ "$choice" == "2" ]]; then
        read -p "✏️  Enter text to exclude: " exc_text
        echo -e "\n\n"
        NEW_TARGETS=()
        for t in "${TARGETS[@]}"; do
            if ! echo "$t" | grep -q -i "$exc_text"; then NEW_TARGETS+=("$t"); fi
        done
        TARGETS=("${NEW_TARGETS[@]}")
        echo -e "  ✅ 🟡 ${YELLOW}Exception${NC} applied!\n\n"
    elif [[ "$choice" == "0" ]]; then echo -e "  ⏭️ [SKIPPED]\n\n"; break
    else echo -e "  ❌ Invalid choice.\n\n"; fi
done

echo -e "  ${YELLOW}[2/2]${NC} ⚙️ Executing System Optimizations...\n\n"

if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then
    dnf autoremove -y >/dev/null 2>&1; dnf makecache -q >/dev/null 2>&1
elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then
    apt autoremove -y >/dev/null 2>&1; apt update -qq >/dev/null 2>&1
elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then
    ORPHANS=$(pacman -Qtdq)
    if [ -n "$ORPHANS" ]; then pacman -Rns $ORPHANS --noconfirm >/dev/null 2>&1; fi
fi

if command -v flatpak &> /dev/null; then flatpak uninstall --unused -y >/dev/null 2>&1; fi
if command -v docker &> /dev/null; then docker builder prune -a -f >/dev/null 2>&1; docker image prune -f >/dev/null 2>&1; fi

journalctl --vacuum-time=3d >/dev/null 2>&1

echo -e "  ✅ System optimizations applied!\n\n"

echo -e "${CYAN}========================================${NC}\n\n"
