# 1. Enter as Root
sudo su

# 2. Prepare partitions (Based on your GParted image)
mount /dev/nvme0n1p1 /mnt
mount /dev/nvme0n1p2 /mnt/boot/efi

# 3. Bind system files
mount --bind /dev /mnt/dev
mount --bind /proc /mnt/proc
mount --bind /sys /mnt/sys

# 4. Enter the system on the hard drive
chroot /mnt

# --- (You are now inside chroot) ---

# 5. Delete the broken net file
rm -f /etc/resolv.conf

# 6. Create a new net file and write Google DNS in it
echo "nameserver 8.8.8.8" > /etc/resolv.conf

# 7. Test the internet
ping -c 3 google.com
