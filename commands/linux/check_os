#!/usr/bin/env bash

###############################################################################
# Terminal Shortcuts
# check_system
#
# Professional Linux Health Check
#
# Supports:
#   Fedora
#   Ubuntu
#   Debian
#   Arch
###############################################################################

set -euo pipefail

###############################################################################
# Colors
###############################################################################

RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
GRAY="\e[90m"
RESET="\e[0m"

###############################################################################
# Report File
###############################################################################

REPORT="linux_health_report.txt"

exec > >(tee "$REPORT") 2>&1

###############################################################################
# Title
###############################################################################

echo
echo "=============================================================="
echo "               🖥️  TERMINAL SHORTCUTS HEALTH CHECK  🖥️"
echo "=============================================================="
echo
echo "📅 Started : $(date)"
echo "🌐 Hostname: $(hostname)"
echo "🐧 Kernel  : $(uname -r)"
echo "👤 User    : $(whoami)"
echo

###############################################################################
# Summary Variables
###############################################################################

DISK_STATUS="PASS"
INTERNET_STATUS="PASS"
FILESYSTEM_STATUS="PASS"

BIOS_WARNING=""
SNAP_WARNING=""
BROADCOM_WARNING=""
BROKEN_WARNING=""
LSHW_WARNING=""
TEMP_WARNING=""
SERVICE_WARNING=""
SMART_WARNING=""

BROKEN_PKGS="NO"
FAILED_SERVICES="NO"
ACPI_ERRORS="NO"
BROADCOM_DRIVER="NO"
LSHW_STATUS="INSTALLED"

OVERALL_STATUS="GOOD"

###############################################################################
# Helper Functions
###############################################################################

good() {
    echo -e "${GREEN}✅${RESET} $1"
}

warn() {
    echo -e "${YELLOW}⚠️${RESET} $1"
}

fail() {
    echo -e "${RED}❌${RESET} $1"
}

info() {
    echo -e "${CYAN}ℹ️${RESET} $1"
}

section() {
    echo
    echo "=============================================================="
    echo "$1"
    echo "=============================================================="
}

###############################################################################
# Update Overall Status
###############################################################################

set_warning() {
    if [[ "$OVERALL_STATUS" == "GOOD" ]]; then
        OVERALL_STATUS="WARNING"
    fi
}

set_critical() {
    OVERALL_STATUS="CRITICAL"
}

###############################################################################
# Detect Package Manager
###############################################################################

PACKAGE_MANAGER="unknown"

if command -v dnf >/dev/null 2>&1; then
    PACKAGE_MANAGER="dnf"
elif command -v apt >/dev/null 2>&1; then
    PACKAGE_MANAGER="apt"
elif command -v pacman >/dev/null 2>&1; then
    PACKAGE_MANAGER="pacman"
fi

info "Package Manager : $PACKAGE_MANAGER"

###############################################################################
# Detect Main Disk Automatically
###############################################################################

DISK=""

if lsblk -dn -o NAME,TYPE | grep -q '^nvme.*disk'; then
    DISK="/dev/$(lsblk -dn -o NAME,TYPE | awk '$2=="disk"{print $1;exit}')"
else
    DISK="/dev/$(lsblk -dn -o NAME,TYPE | awk '$2=="disk"{print $1;exit}')"
fi

info "Detected Disk : $DISK"

###############################################################################
# Check Required Commands
###############################################################################

MISSING=()

for cmd in \
    lsblk \
    systemctl \
    journalctl \
    dmesg \
    ping \
    awk \
    grep \
    free \
    df
do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        MISSING+=("$cmd")
    fi
done

if (( ${#MISSING[@]} > 0 )); then
    fail "Missing required commands:"
    printf ' - %s\n' "${MISSING[@]}"
    exit 1
fi

###############################################################################
# Start Scan
###############################################################################

echo
echo "🔍 Scanning the entire system... Please wait ⏳"
echo
sleep 1

###############################################################################
# Check Updates
###############################################################################

section "[1/8] 📦 Package Updates"

case "$PACKAGE_MANAGER" in
dnf)
    if sudo dnf check-update -q >/dev/null 2>&1; then
        good "Repositories are reachable."
    else
        warn "Updates are available or repository issue detected."
        set_warning
    fi
;;
apt)
    if sudo apt update -qq >/dev/null 2>&1; then
        good "Repositories are reachable."
    else
        warn "Unable to update package lists."
        set_warning
    fi
;;
pacman)
    if sudo pacman -Sy --noconfirm >/dev/null 2>&1; then
        good "Repositories are reachable."
    else
        warn "Unable to synchronize repositories."
        set_warning
    fi
;;
*)
    warn "Unsupported package manager."
;;
esac

###############################################################################
# Broken Packages
###############################################################################

section "[2/8] 🧩 Broken Packages"

BROKEN_PKGS="NO"

case "$PACKAGE_MANAGER" in
dnf)
    if sudo dnf repoquery --unsatisfied | grep -q .; then
        BROKEN_PKGS="YES"
        BROKEN_WARNING="⚠️ Broken Packages Found"
        warn "Broken packages detected."
        sudo dnf repoquery --unsatisfied
        set_warning
    else
        good "No broken packages found."
    fi
;;
apt)
    if sudo dpkg --audit | grep -q .; then
        BROKEN_PKGS="YES"
        BROKEN_WARNING="⚠️ Broken Packages Found"
        warn "Broken packages detected."
        sudo dpkg --audit
        set_warning
    else
        good "No broken packages found."
    fi
;;
pacman)
    if sudo pacman -Qk | grep -q warning; then
        BROKEN_PKGS="YES"
        BROKEN_WARNING="⚠️ Broken Packages Found"
        warn "Broken packages detected."
        sudo pacman -Qk
        set_warning
    else
        good "No broken packages found."
    fi
;;
esac

###############################################################################
# Internet
###############################################################################

section "[3/8] 🌐 Internet"

if ping -c2 8.8.8.8 >/dev/null 2>&1; then
    good "Internet connection OK."
else
    INTERNET_STATUS="FAIL"
    fail "Internet connection failed."
    set_critical
fi

###############################################################################
# Disk Usage
###############################################################################

section "[4/8] 💾 Storage"

df -h

USAGE=$(df / | awk 'END{gsub("%","");print $5}')

echo

if (( USAGE < 80 )); then
    good "Disk usage: ${USAGE}%"
elif (( USAGE < 90 )); then
    warn "Disk usage: ${USAGE}%"
    set_warning
else
    fail "Disk usage: ${USAGE}%"
    set_critical
fi

###############################################################################
# SMART
###############################################################################

section "[5/8] 🩺 SMART Health"

if command -v smartctl >/dev/null 2>&1; then
    if sudo smartctl -H "$DISK" | grep -q PASSED; then
        good "Disk health PASSED."
    else
        DISK_STATUS="FAIL"
        SMART_WARNING="⚠️ SMART Errors Detected"
        fail "Disk SMART reports problems."
        sudo smartctl -H "$DISK"
        set_critical
    fi
else
    info "smartctl not installed."
fi

###############################################################################
# CPU Temperature
###############################################################################

section "[6/8] 🌡️ CPU Temperature"

if command -v sensors >/dev/null 2>&1; then
    TEMP=$(sensors | awk '
        /Package id 0:/{
            gsub("\\+","",$4)
            gsub("°C","",$4)
            print int($4)
            exit
        }
        /Tctl:/{
            gsub("\\+","",$2)
            gsub("°C","",$2)
            print int($2)
            exit
        }
    ')

    if [[ -n "$TEMP" ]]; then
        echo "Temperature : ${TEMP}°C"
        if (( TEMP < 80 )); then
            good "Temperature normal."
        elif (( TEMP < 90 )); then
            TEMP_WARNING="⚠️ High CPU Temperature"
            warn "CPU temperature is high."
            set_warning
        else
            TEMP_WARNING="⚠️ Critical CPU Temperature"
            fail "CPU temperature is critical."
            set_critical
        fi
    else
        info "Temperature sensor not available."
    fi
else
    info "lm-sensors not installed."
fi

###############################################################################
# Swap
###############################################################################

section "[7/8] 💤 Swap"

if swapon --show | grep -q .; then
    good "Swap is active."
    free -h | grep Swap
else
    warn "No active swap."
    set_warning
fi

###############################################################################
# Failed Services
###############################################################################

section "[8/8] ⚙️ Failed Services"

FAILED=$(systemctl --failed --no-legend)
FAILED_SERVICES="NO"

if [[ -z "$FAILED" ]]; then
    good "No failed services."
else
    FAILED_SERVICES="YES"
    SERVICE_WARNING="⚠️ Failed Services Detected"
    warn "Some services failed."
    echo
    systemctl --failed
    set_warning
fi

###############################################################################
# BIOS / ACPI
###############################################################################

section "[9/13] 🧬 BIOS & ACPI"

ACPI_ERRORS="NO"

if dmesg | grep -Ei "ACPI BIOS Error|Firmware Bug|AE_AML|No valid trip points" >/tmp/acpi_errors.$$ 2>/dev/null
then
    ACPI_ERRORS="YES"
    BIOS_WARNING="⚠️ BIOS / ACPI Errors"
    warn "BIOS/ACPI issues detected."
    cat /tmp/acpi_errors.$$
    set_warning
else
    good "No BIOS / ACPI errors found."
fi

rm -f /tmp/acpi_errors.$$

###############################################################################
# Broadcom Driver
###############################################################################

section "[10/13] 📶 Wireless Driver"

BROADCOM_DRIVER="NO"

if lsmod | grep -q "^wl"
then
    BROADCOM_DRIVER="YES"
    BROADCOM_WARNING="⚠️ Proprietary Broadcom Driver Detected"
    warn "Broadcom STA driver detected."
    warn "This driver is proprietary and may cause kernel warnings."
    set_warning
elif lsmod | grep -q "^iwlwifi"
then
    good "Intel wireless driver detected."
elif lsmod | grep -q "^ath"
then
    good "Qualcomm/Atheros wireless driver detected."
else
    info "Wireless driver not recognized."
fi

###############################################################################
# lshw
###############################################################################

section "[11/13] 🛠️ Hardware Inventory"

LSHW_STATUS="INSTALLED"

if command -v lshw >/dev/null
then
    good "lshw installed."
    sudo lshw -short
else
    LSHW_STATUS="MISSING"
    LSHW_WARNING="ℹ️ lshw Not Installed"
    info "Install it for complete hardware information."
fi

###############################################################################
# Kernel Errors
###############################################################################

section "[12/13] 🐧 Kernel Errors"

ERRORS=$(journalctl -k -p err -b --no-pager 2>/dev/null)

if [[ -n "$ERRORS" ]]
then
    warn "Kernel errors detected."
    echo
    echo "$ERRORS"
    set_warning
else
    good "No kernel errors."
fi

###############################################################################
# Journal Errors
###############################################################################

section "[13/13] 📜 System Journal"

JOURNAL=$(journalctl -p err -b --no-pager 2>/dev/null)

if [[ -n "$JOURNAL" ]]
then
    warn "System errors detected."
    echo
    echo "$JOURNAL"
    set_warning
else
    good "No system errors."
fi

###############################################################################
# Hardware Information
###############################################################################

section "🖥️ Hardware Summary"

echo "Hostname      : $(hostname)"
echo "Kernel        : $(uname -r)"
echo "Architecture  : $(uname -m)"
echo "CPU           : $(lscpu | awk -F: '/Model name/{print $2;exit}')"

echo
echo "💾 Memory"
free -h

echo
echo "💿 Disks"
lsblk

echo
echo "🔌 PCI Devices"
lspci

echo
echo "🖱️ USB Devices"
lsusb

###############################################################################
# Network
###############################################################################

section "📡 Network"

ip addr

echo

ip route

###############################################################################
# Filesystems
###############################################################################

section "📂 Mounted Filesystems"

findmnt

###############################################################################
# NVMe Information
###############################################################################

if command -v nvme >/dev/null && [[ "$DISK" == *nvme* ]]
then
    section "💿 NVMe Information"
    sudo nvme list
fi

###############################################################################
# SELinux
###############################################################################

section "🛡️ SELinux"

if command -v getenforce >/dev/null 2>&1; then
    MODE=$(getenforce)
    echo "Mode : $MODE"
    if [[ "$MODE" == "Enforcing" ]]; then
        good "SELinux is active."
    else
        warn "SELinux is not enforcing."
        set_warning
    fi
fi

###############################################################################
# Health Summary
###############################################################################

section "📊 Health Summary"

good "Disk Health: $DISK_STATUS"
good "Internet: $INTERNET_STATUS"
good "Filesystem: $FILESYSTEM_STATUS"

[[ "$ACPI_ERRORS" == "YES" ]] && warn "🧬 BIOS ACPI Errors"
[[ "$FAILED_SERVICES" == "YES" ]] && warn "⚙️ Failed System Services"
[[ "$BROADCOM_DRIVER" == "YES" ]] && warn "📶 Proprietary Broadcom Driver Detected"
[[ "$BROKEN_PKGS" == "YES" ]] && warn "🧩 Broken Packages Found"
[[ "$LSHW_STATUS" == "MISSING" ]] && info "🛠️ lshw Not Installed"

###############################################################################
# Overall Status
###############################################################################

section "🏁 Overall Status"

if [[ "$OVERALL_STATUS" == "GOOD" ]]; then
    good "EXCELLENT"
elif [[ "$OVERALL_STATUS" == "WARNING" ]]; then
    warn "GOOD"
else
    fail "CRITICAL"
fi

echo
echo "📄 Report saved to:"
echo "$REPORT"

echo
echo "✅ Scan complete."
