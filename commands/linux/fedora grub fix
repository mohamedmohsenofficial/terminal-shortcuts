#!/bin/bash

# =========================================================
# ===    Fedora GRUB Repair Script (For Your Device)     ===
# === Based on: Root=/dev/nvme0n1p1 | EFI=/dev/nvme0n1p2 ===
# =========================================================

# Ensure the script runs with root privileges
if [ "$EUID" -ne 0 ]; then
  echo "Error: This script must be run as root"
  echo "Use the command: sudo ./repair.sh"
  exit 1
fi

# --- 1. Define partitions (Based on your device) ---
ROOT_PART="/dev/nvme0n1p1"
EFI_PART="/dev/nvme0n1p2"
MNT_DIR="/mnt/fedora_rescue"

echo "--- Starting repair process ---"

# --- 2. Prepare mount environment ---
echo "1. Preparing mount point at: $MNT_DIR"
mkdir -p $MNT_DIR
umount -R $MNT_DIR 2>/dev/null # To ensure it is not in use

# --- 3. Mount partitions ---
echo "2. Mounting Root partition ($ROOT_PART)..."
# You are using ext4, not btrfs
mount $ROOT_PART $MNT_DIR
if [ $? -ne 0 ]; then
    echo "Failed to mount Root. Exiting."
    exit 1
fi

echo "3. Mounting EFI partition ($EFI_PART)..."
mount $EFI_PART $MNT_DIR/boot/efi
if [ $? -ne 0 ]; then
    echo "Failed to mount EFI. Exiting."
    umount -R $MNT_DIR
    exit 1
fi

# --- 4. Bind live system systems ---
echo "4. Binding live system to chroot environment..."
mount --bind /dev $MNT_DIR/dev
mount --bind /dev/pts $MNT_DIR/dev/pts
mount --bind /proc $MNT_DIR/proc
mount --bind /sys $MNT_DIR/sys

# --- 5. Enter and perform actual repair ---
echo "5. Entering chroot and executing repair commands..."
chroot $MNT_DIR /bin/bash -c "
    echo '    [Inside chroot]: Reinstalling boot packages...'
    dnf reinstall -y shim-* grub2-efi-* grub2-common
    
    echo '    [Inside chroot]: Updating GRUB menu to detect Windows...'
    grub2-mkconfig -o /boot/grub2/grub.cfg
    
    echo '    [Inside chroot]: ... Repair completed. Exiting.'
"
echo "6. Repair completed."

# --- 6. Cleanup and exit ---
echo "7. Unmounting disks and cleaning up environment..."
umount -R $MNT_DIR
rmdir $MNT_DIR

echo "---"
echo "Success! Everything has been completed successfully!"

# 1. The command that was failing (it will work this time)
dnf reinstall -y grub2-efi-x64 shim-*

# 2. Build boot list (to detect Windows)
grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg

# 3. Exit chroot
exit

echo "You can now restart and remove the flash drive."
echo "---"
