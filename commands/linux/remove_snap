#!/usr/bin/env bash

# Colors
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}[ERROR] Please run this script as root (using sudo)${NC}\n\n"
  exit 1
fi

USER_HOME=$(eval echo ~$SUDO_USER)
[[ -z "$USER_HOME" || "$USER_HOME" == "/" ]] && USER_HOME=$HOME

echo -e "${CYAN}========================================${NC}\n\n"

echo -e "  Snap Universal Complete Removal Script\n\n"

echo -e "${CYAN}========================================${NC}\n\n"

# 1. Stop and disable snapd service
echo -e "${YELLOW}[1/4] Stopping snapd service...${NC}\n\n"
systemctl stop snapd 2>/dev/null
systemctl disable snapd 2>/dev/null
systemctl disable snapd.socket 2>/dev/null
systemctl disable snapd.seeded 2>/dev/null

# 2. Identify Package Manager and Remove Snapd
echo -e "${YELLOW}[2/4] Removing snapd package...${NC}\n\n"

if command -v apt &> /dev/null; then
    apt purge snapd -y
elif command -v dnf &> /dev/null; then
    dnf remove snapd -y
elif command -v pacman &> /dev/null; then
    pacman -Rns snapd --noconfirm
else
    echo -e "${RED}[WARN] Could not detect package manager to remove snapd binary.${NC}\n\n"
fi

# 3. Remove all snap data directories (Universal locations)
echo -e "${YELLOW}[3/4] Removing all snap data directories...${NC}\n\n"
rm -rf /var/cache/snapd
rm -rf /var/lib/snapd
rm -rf /snap
rm -rf /var/snap
rm -rf /home/*/snap
rm -rf "$USER_HOME/snap"

# 4. Cleanup Mount Units
echo -e "${YELLOW}[4/4] Cleaning mount units...${NC}\n\n"
# This clears the failed mount entries you saw in systemctl
systemctl daemon-reload
systemctl reset-failed

echo -e "${GREEN}[OK] Snap has been completely removed from the system.${NC}\n\n"

echo -e "${CYAN}========================================${NC}\n\n"

echo -e "  IMPORTANT: Please RESTART your system to complete the cleanup.\n\n"
