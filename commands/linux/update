#!/usr/bin/env bash

# Colors for emphasis
RED='\033[1;31m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; CYAN='\033[1;36m'; GRAY='\033[1;30m'; NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}[ERROR] Please run this script as root (using sudo)${NC}\n"
  exit 1
fi

USER_HOME=$(eval echo ~$SUDO_USER)
[[ -z "$USER_HOME" || "$USER_HOME" == "/" ]] && USER_HOME=$HOME

echo -e "${CYAN}========================================${NC}\n"

echo -e "  🚀 Linux Master Updater & Cleaner\n"

echo -e "${CYAN}========================================${NC}\n"

if [ -f /etc/os-release ]; then . /etc/os-release; OS=$ID; OS_LIKE=$ID_LIKE; fi

# 1. Scanning Phase
echo -e "  ${YELLOW}[1/4]${NC} 🔵 ${CYAN}Scanning${NC} for OS and App updates...\n"

echo -e "  🔍 Checking System Packages...\n"
if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then
    dnf check-update -q || true
elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then
    apt update -qq
    apt list --upgradable 2>/dev/null | head -n 10
    echo -e "  (Showing top 10 upgradable packages...)\n"
elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then
    pacman -Qu || echo -e "  ✅ System is up to date.\n"
fi
echo -e "\n"

echo -e "  🔍 Checking Flatpak Apps...\n"
if command -v flatpak &> /dev/null; then
    flatpak remote-ls --updates
else
    echo -e "  (Flatpak not installed)\n"
fi
echo -e "\n"

echo -e "  🔍 Checking Firmware...\n"
if command -v fwupdmgr &> /dev/null; then
    fwupdmgr get-updates || true
else
    echo -e "  (fwupdmgr not installed)\n"
fi
echo -e "\n"

# 2. User Confirmation
echo -e "${CYAN}========================================${NC}\n"

echo -e "  1. 🟢 ${GREEN}Approve${NC} & ${GREEN}Update${NC} Everything (OS + Apps)\n"

echo -e "  0. ❌ ${GRAY}Skip${NC} / ${RED}Cancel${NC} Updates\n"

read -p "👉 Choice (0-1): " choice
echo -e "\n"

if [[ "$choice" == "1" ]]; then
    
    # 3. Executing Updates
    echo -e "  ${YELLOW}[2/4]${NC} ⏳ Executing 🟢 ${GREEN}Updates${NC}...\n"
    
    if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then
        dnf upgrade --refresh -y
        dnf update -y
    elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then
        apt upgrade -y
        apt full-upgrade -y
    elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then
        pacman -Syu --noconfirm
    fi
    echo -e "\n  ✅ OS updated successfully!\n"

    if command -v flatpak &> /dev/null; then
        echo -e "  🔄 Updating Flatpak applications...\n"
        flatpak update -y
    fi

    if command -v fwupdmgr &> /dev/null; then
        echo -e "\n  🔄 Updating Firmware...\n"
        fwupdmgr refresh --force
        fwupdmgr update -y
    fi

    # 4. Cleaning Garbage & Applying User Original Commands
    echo -e "\n  ${YELLOW}[3/4]${NC} 🧹 Cleaning 🔴 ${RED}Garbage${NC} & Rebuilding Caches...\n"
    
    if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then
        dnf autoremove -y
        dnf clean all
        rm -rf /var/cache/dnf/*
        dnf makecache
        dnf check-update || true
    elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then
        apt autoremove -y
        apt autoclean -y
        apt clean
        rm -rf /var/cache/apt/archives/*
        apt update -qq
    elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then
        ORPHANS=$(pacman -Qtdq)
        if [ -n "$ORPHANS" ]; then pacman -Rns $ORPHANS --noconfirm; fi
        pacman -Sc --noconfirm
        rm -rf /var/cache/pacman/pkg/*
    fi

    if command -v flatpak &> /dev/null; then
        flatpak uninstall --unused -y
    fi

    echo -e "\n  🧹 Cleaning Thumbnails...\n"
    rm -rf "$USER_HOME/.cache/thumbnails/"*

    echo -e "\n  🧹 Vacuuming Journal Logs (Keeping last 3 days)...\n"
    journalctl --vacuum-time=3d

    echo -e "\n  ⚙️  Configuring Journal Size Limit (50M)...\n"
    if [ -f /etc/systemd/journald.conf ]; then
        sed -i 's/.*SystemMaxUse=.*/SystemMaxUse=50M/' /etc/systemd/journald.conf
        systemctl restart systemd-journald
    fi

    echo -e "\n  🧹 Cleaning ABRT and Coredump logs...\n"
    rm -rf /var/spool/abrt/*
    rm -rf /var/lib/systemd/coredump/*

    # 5. Final Output & Sizes
    echo -e "\n  ${YELLOW}[4/4]${NC} 📊 System Report:\n"
    
    if command -v fwupdmgr &> /dev/null; then
        echo -e "  📜 Firmware Update History:\n"
        fwupdtool get-history | head -n 15
        echo -e "\n"
    fi

    echo -e "  📦 Cache Size After Cleanup:\n"
    if [[ "$OS" == "fedora" || "$OS_LIKE" == *"fedora"* ]]; then
        du -sh /var/cache/dnf 2>/dev/null || echo "0"
    elif [[ "$OS" == "debian" || "$OS" == "ubuntu" || "$OS_LIKE" == *"debian"* ]]; then
        du -sh /var/cache/apt/archives 2>/dev/null || echo "0"
    elif [[ "$OS" == "arch" || "$OS_LIKE" == *"arch"* ]]; then
        du -sh /var/cache/pacman/pkg 2>/dev/null || echo "0"
    fi
    echo -e "\n"

    echo -e "  ✅ System Update, Cleanup, and Cache Refresh Complete!\n"

else
    echo -e "  ⏭️ ${YELLOW}Pending${NC} updates were skipped.\n"
fi

echo -e "${CYAN}========================================${NC}\n"
