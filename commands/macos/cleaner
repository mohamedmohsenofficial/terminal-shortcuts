#!/usr/bin/env bash

RED='\033[1;31m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; CYAN='\033[1;36m'; WHITE='\033[1;37m'; NC='\033[0m'
PROTECTED_REGEX="(code|vscode|codium|docker|containers|apple|system|crashreporter|mobilesync|homebrew|safari)"

echo -e "${CYAN}========================================${NC}\n\n"

echo -e "  🚀 macOS Master Cleaner\n\n"

echo -e "${CYAN}========================================${NC}\n\n"

echo -e "  ${YELLOW}[1/2]${NC} 🔵 ${CYAN}Scanning${NC} 🔴 ${RED}Garbage${NC} & Caches...\n\n"

TARGETS=()
if command -v brew &> /dev/null; then TARGETS+=("$(brew --cache)"); fi

while IFS= read -r -d '' dir; do TARGETS+=("$dir")
done < <(find ~/Library/Caches -mindepth 1 -maxdepth 1 -print0 2>/dev/null | grep -z -E -v -i "$PROTECTED_REGEX")

if [ -d "$HOME/Library/Application Support" ]; then
    for DIR_PATH in "$HOME/Library/Application Support"/*; do
        [ ! -d "$DIR_PATH" ] && continue
        DIR_NAME=$(basename "$DIR_PATH")
        if echo "$DIR_NAME" | grep -q -E -i "$PROTECTED_REGEX"; then continue; fi
        APP_EXISTS=$(find /Applications -maxdepth 2 -iname "*${DIR_NAME}*.app" 2>/dev/null)
        if [ -z "$APP_EXISTS" ]; then TARGETS+=("$DIR_PATH"); fi
    done
fi

while [ ${#TARGETS[@]} -gt 0 ]; do
    echo -e "🔍 Found disposable caches and orphans:\n\n"
    sudo du -shc "${TARGETS[@]}" 2>/dev/null | grep -v "total"
    TOTAL_CACHE=$(sudo du -shc "${TARGETS[@]}" 2>/dev/null | grep "total" | awk '{print $1}')
    
    echo -e "\nTotal Wasted Space: \033[1;31m$TOTAL_CACHE\033[0m\n\n"
    
    echo -e "  1. ✅ 🟢 ${GREEN}Approve${NC} & 🔴 ${RED}Delete${NC} All\n\n"
    
    echo -e "  2. ➕ Add 🟡 ${YELLOW}Exception${NC} (Skip a folder)\n\n"
    
    echo -e "  0. ❌ ⚪ ${WHITE}Skip${NC} Cleanup\n\n"
    
    read -p "👉 Choice (0-2): " choice
    echo -e "\n\n"
    
    if [[ "$choice" == "1" ]]; then
        for t in "${TARGETS[@]}"; do sudo rm -rf "$t" 2>/dev/null; done
        echo -e "  ✅ [OK] 🔴 ${RED}Garbage${NC} cleared.\n\n"; break
    elif [[ "$choice" == "2" ]]; then
        read -p "✏️  Enter text to exclude: " exc_text
        echo -e "\n\n"
        NEW_TARGETS=()
        for t in "${TARGETS[@]}"; do
            if ! echo "$t" | grep -q -i "$exc_text"; then NEW_TARGETS+=("$t"); fi
        done
        TARGETS=("${NEW_TARGETS[@]}")
        echo -e "  ✅ 🟡 ${YELLOW}Exception${NC} applied!\n\n"
    elif [[ "$choice" == "0" ]]; then echo -e "  ⏭️ [SKIPPED]\n\n"; break
    else echo -e "  ❌ Invalid choice.\n\n"; fi
done

echo -e "  ${YELLOW}[2/2]${NC} ⚙️ Executing System Optimizations...\n\n"

if command -v brew &> /dev/null; then brew autoremove >/dev/null 2>&1; brew cleanup -s >/dev/null 2>&1; fi
if command -v docker &> /dev/null; then docker builder prune -a -f >/dev/null 2>&1; docker image prune -f >/dev/null 2>&1; fi
sudo rm -rf /Library/Updates/* 2>/dev/null

echo -e "  ✅ System optimizations applied!\n\n"

echo -e "${CYAN}========================================${NC}\n\n"
